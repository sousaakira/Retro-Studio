{
  "name": "retro-studio",
  "private": true,
  "version": "0.6.0",
  "type": "module",
  "main": "electron/main.js",
  "author": "Retro Studio Team",
  "description": "Retro Studio - IDE para desenvolvimento Sega Mega Drive / SGDK",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "build:mac": "npm run build && electron-builder --mac",
    "build:all": "npm run build && electron-builder -mwl",
    "preview": "electron-vite preview",
    "lint": "eslint ."
  },
  "build": {
    "appId": "com.retro-studio.app",
    "productName": "Retro Studio",
    "directories": {
      "buildResources": "assets/icons",
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "RetroStudio-${version}-${arch}.${ext}",
      "icon": "assets/icons/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Retro Studio"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "RetroStudio-${version}-${arch}.${ext}",
      "icon": "assets/icons/icon.png",
      "category": "Development",
      "maintainer": "Retro Studio Team"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "RetroStudio-${version}.${ext}",
      "icon": "assets/icons/icon.png",
      "category": "public.app-category.developer-tools"
    }
  },
  "dependencies": {
    "@monaco-editor/loader": "^1.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "extract-zip": "^2.0.1",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.1",
    "monaco-editor": "^0.52.0",
    "monaco-editor-vue3": "^0.1.10",
    "node-pty": "^1.0.0",
    "vue": "^3.5.13",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^32.2.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^2.2.0",
    "eslint": "^9.15.0",
    "vite": "^5.4.11",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vite-plugin-static-copy": "^3.1.4"
  }
}
